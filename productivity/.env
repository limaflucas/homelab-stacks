# --- General ---
NODE_ENV=production
URL=http://localhost:3000
PORT=3000

# Generate these with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_random_hex_32
UTILS_SECRET=change_me_to_a_random_hex_32

# --- Database ---
# Replace 'your_db_password' with the same value as POSTGRES_PASSWORD
DATABASE_URL=postgres://outline:your_db_password@postgres:5432/outline
DATABASE_CONNECTION_POOL_MIN=2
DATABASE_CONNECTION_POOL_MAX=20
POSTGRES_PASSWORD=your_db_password

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Storage (MinIO) ---
AWS_ACCESS_KEY_ID=outline_user
AWS_SECRET_ACCESS_KEY=outline_password
AWS_REGION=us-east-1
AWS_S3_ACL=private
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_ENDPOINT=http://minio:9000
AWS_S3_UPLOAD_BUCKET_URL=http://localhost:9000
AWS_S3_UPLOAD_BUCKET_NAME=outline
AWS_S3_UPLOAD_MAX_SIZE=26214400

# --- MinIO Initialization ---
MINIO_ROOT_USER=outline_user
MINIO_ROOT_PASSWORD=outline_password

# --- Authentication (OIDC via Authelia) ---
# This is a placeholder. You will need to configure Authelia to match these.
OIDC_CLIENT_ID=outline
OIDC_CLIENT_SECRET=outline_oidc_secret
OIDC_AUTH_URI=http://localhost:9091/api/oidc/authorization
OIDC_TOKEN_URI=http://localhost:9091/api/oidc/token
OIDC_USERINFO_URI=http://localhost:9091/api/oidc/userinfo
OIDC_DISPLAY_NAME=Authelia
OIDC_SCOPES=openid profile email
